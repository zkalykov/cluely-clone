{
  "name": "ai-assistant",
  "version": "1.0.0",
  "description": "AI Assistant — a screen- and audio-aware AI helper: a browser app (chat, meeting notes, history) plus a stealth desktop overlay.",
  "main": "src/main/index.js",
  "bin": {
    "cluely-clone": "src/web/server.js",
    "ai-assistant": "src/web/server.js"
  },
  "files": [
    "src/**/*",
    "package.json",
    "README.md"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "node src/web/server.js",
    "web": "node src/web/server.js",
    "overlay": "electron .",
    "dev": "node scripts/dev.js",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.local.aiassistant",
    "productName": "AI Assistant",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "AI Assistant listens to questions to transcribe and answer them.",
        "LSUIElement": true
      }
    }
  }
}
