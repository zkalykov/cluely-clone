# ── Authentication ─────────────────────────────────────────────────────────
# EASIEST — leave everything below blank. If you have the `claude` CLI (Claude
# Code) installed and logged in, the app drives it directly using your terminal
# login. No API key, nothing to paste.
#
# Or, to use the Anthropic API directly, set ONE of these:
#   A) a long-lived token from `claude setup-token`:
ANTHROPIC_AUTH_TOKEN=
#   B) a classic console API key (https://console.anthropic.com/):
ANTHROPIC_API_KEY=
#
# Provider resolution: ANTHROPIC_API_KEY → ANTHROPIC_AUTH_TOKEN → `ant` profile
#   → local `claude` CLI. Force one with CLUELY_PROVIDER below.
# CLUELY_PROVIDER=          # api | claude-cli  (blank = auto)
# CLUELY_CLI_MODEL=         # model for the claude CLI (blank = your Claude Code default)
# ANTHROPIC_BASE_URL=       # override API base URL (rarely needed)

# ── Optional: voice transcription ──────────────────────────────────────────
# Needed only for the "Listen" feature (mic -> transcript -> answer).
# Anthropic has no audio endpoint, so transcription uses OpenAI Whisper.
# Screenshot-solve and typed questions work without this.
OPENAI_API_KEY=

# ── Optional: tuning ───────────────────────────────────────────────────────
# Claude model id. Default is the most capable Opus.
CLUELY_MODEL=claude-opus-4-8
# Reasoning effort: low | medium | high | xhigh | max. Higher = smarter, slower.
# medium is a good balance for live use; bump to high/xhigh for hard problems.
CLUELY_EFFORT=medium
# Show the model's summarized reasoning while it works: on | off
CLUELY_THINKING=on
# Max output tokens per answer.
CLUELY_MAX_TOKENS=8000
# Whisper model used for transcription (whisper-1 is widely available).
CLUELY_STT_MODEL=whisper-1
# Stealth: hide the Dock icon / Cmd-Tab entry. Off by default because a
# dock-hidden app can't reliably take keyboard focus on macOS. Set to 1 only if
# typing/hotkeys still work for you. (The window is invisible to screen-share
# either way — that's content protection, not this setting.)
CLUELY_STEALTH=0
